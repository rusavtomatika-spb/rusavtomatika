DefaultLanguage ru
AddDefaultCharset windows-1251

RewriteEngine On

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /catalog/index.php?component=catalog_detail&q=$1 [QSA,L]

RewriteRule ^images/(.*)$ https://www.rusavtomatika.com/upload_files/images/$1 [L,R=301]
RewriteRule ^upload_files/(.*)$ https://www.rusavtomatika.com/upload_files/$1 [L,R=301]