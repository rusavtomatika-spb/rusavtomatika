DefaultLanguage ru
AddDefaultCharset windows-1251

RewriteEngine On

RewriteRule ^images/(.*)$ https://www.rusavtomatika.com/images/$1 [L,R=301]
RewriteRule ^upload_files/(.*)$ https://www.rusavtomatika.com/upload_files/$1 [L,R=301]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?q=$1 [QSA,L]