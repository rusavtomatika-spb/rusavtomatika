DefaultLanguage ru
AddDefaultCharset windows-1251

RewriteEngine On

RewriteRule ^images/(.*)$ https://www.rusavtomatika.com/articles/images/$1 [L,R=301]
RewriteRule ^upload_files/(.*)$ https://www.rusavtomatika.com/upload_files/$1 [L,R=301]

RewriteRule ^$ index.php [L]

RewriteRule ^discounted/?$ discounted/index.php [L,QSA]
RewriteRule ^discounted/([a-zA-Z0-9\-_]+)/?$ discounted/index.php?q=$1 [L,QSA]

RewriteRule ^discounted/product_item\.link/?$ /sale/discounted/ [L,R=301]