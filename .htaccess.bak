#RewriteCond %{THE_REQUEST} \s[/?]{2,}(?:.*)[/?]{2,}([\w\d-_]*)[/?]{2,}[^\?]\s [NC,OR]





#RewriteCond %{THE_REQUEST} \s[/?]{2,}(?:.*)[/?]{2,}([\w\d-_]*)/[^\?]\s [NC,OR]





#RewriteCond %{THE_REQUEST} \s[/?]{2,}(?:.*)/([\w\d-_]*)[/?]{2,}[^\?]\s [NC,OR]





#RewriteCond %{THE_REQUEST} \s/(?:.*)[/?]{2,}([\w\d-_]*)[/?]{2,}[^\?]\s [NC]





#RewriteCond %{THE_REQUEST} !\s(?:.*)/\?\s [NC]





#RewriteCond %{QUERY_STRING} !(?:.*)(?:submit)(?:.*) [NC]





#RewriteCond %{REQUEST_URI} !(?:news|articles|soft|updater|updater_source|xml|forum|cart) [NC]





#RewriteCond %{REQUEST_FILENAME} !-f





#RewriteRule (.*)[^soft](.*) https://%{HTTP_HOST}/%1/%2/ [R=301,L]





####################################################





#RewriteCond %{THE_REQUEST} [\s?](?:.*)/([\w\d-_]*?)[/?]{2,}[^\?][\s?] [NC,OR]





#RewriteCond %{THE_REQUEST} [\s?](?:.*)[/?]{2,}([\w\d-_]*?)/[^\?][\s?] [NC,OR]





#RewriteCond %{THE_REQUEST} [\s?](?:.*)[/?]{2,}([\w\d-_]*?)[/?]{2,}[^\?][\s?] [NC]





#RewriteCond %{REQUEST_URI} !(?:news|articles|soft|updater|updater_source|xml|forum|cart) [NC]





#RewriteCond %{QUERY_STRING} !(?:.*)(?:submit)(?:.*) [NC]





#RewriteCond %{REQUEST_FILENAME} !-f





