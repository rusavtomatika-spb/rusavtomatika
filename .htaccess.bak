############# Убираем //////////// в корне #########################





#RewriteCond %{REQUEST_FILENAME} !-f





#RewriteCond %{THE_REQUEST} [\s?][/?]{2,}[\s?] [NC]





#RewriteRule (.*) / [R=301,L]





############### Удаляем & из ?& в documents





RewriteCond %{REQUEST_URI} /(documents|video)/ [NC]





RewriteCond %{QUERY_STRING} !(ebpro|ea20|cmt|mt8000ip|mt8000ie|mtv|emt3000|moduli|other|plc|faq|Weintek-technologies|Weintek-products|Weintek-EasyBuilder-Pro|eWON|zapros) [NC]





RewriteCond %{QUERY_STRING} .





RewriteCond %{QUERY_STRING} !(action|db|files|folder|zapros)





RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI}? [L,R=301]





############### Удаляем & из ?&





RewriteCond %{THE_REQUEST} /\?&(.*?)\s [NC]





#RewriteCond %{QUERY_STRING} (ebpro|ea20|cmt|mt8000ip|mt8000ie|mtv|emt3000|moduli|plc|faq|Weintek-technologies|Weintek-products|Weintek-EasyBuilder-Pro|eWON) [NC]





RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI}/\?%1 [L,R=301]





############### Удаляем страницы со GET-запросами из старого сайта





RewriteCond %{REQUEST_URI} /page[0-9*]/ [NC,OR]





RewriteCond %{REQUEST_URI} /ra/(.*)$ [NC,OR]





#RewriteCond %{THE_REQUEST} /\?& [NC,OR]





#RewriteCond %{REQUEST_URI} /accessories/codesys_license/(.*)$ [NC]





#RewriteRule (.*) $1? [L,R=404]





RewriteCond %{REQUEST_URI} ^/(\w+?)[_+][/*](.*)$ [NC]





RewriteRule (.*) $1? [L,R=404]





RewriteCond %{REQUEST_URI} !/(?:news|articles)/ [NC]





RewriteCond %{THE_REQUEST} ^(GET|HEAD|POST)\ /([^\ \?]*?)\?+\s [NC,OR]





RewriteCond %{THE_REQUEST} ^(GET|HEAD|POST)\ \?+\s [NC]





RewriteRule ^(.*)$ /$1? [L,R=301]





#RewriteCond %{THE_REQUEST} \s/([\w\d-_]*?)/\?(.*)[^=]\s [NC]
RewriteCond %{QUERY_STRING} != [NC]
RewriteCond %{REQUEST_URI} !(?:cart) [NC]
RewriteCond %{REQUEST_URI} !(?:forum) [NC]
RewriteCond %{QUERY_STRING} !(?:.*)(?:submit)(?:.*) [NC]
#RewriteRule (.*) https://%{HTTP_HOST}/%1/? [R=301,L]





############### Удаляем тестовые index, созданные во время разработки. Типа index2.php и т.п.





RewriteCond %{REQUEST_URI} index[0-9+].php$





RewriteRule (.*) $1? [R=404]





############### Удаляем index.php в конце урла





RewriteCond %{REQUEST_URI} index.php$





RewriteCond %{REQUEST_URI} !(?:forum) [NC]





RewriteRule (.*)/index.php$ $1/ [R=301]





RewriteCond %{QUERY_STRING} "utm" [NC]





RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L,QSD]





RewriteCond %{REQUEST_URI} new_products [NC]





RewriteRule ^new_products(.+)$ new-products$1 [R=301,L]





<ifModule mod_expires.c>





ExpiresActive On





ExpiresDefault "access plus 1 days"





ExpiresByType image/x-icon "access plus 1 days"





ExpiresByType image/jpeg "access plus 1 days"





ExpiresByType image/png "access plus 1 days"





ExpiresByType image/gif "access plus 1 days"





ExpiresByType application/x-shockwave-flash "access plus 1 days"





</ifModule>

RewriteRule ^M02\.html/?$ /accessories/M02/ [L,R=301]

<IfModule mime_module>





  AddHandler application/x-httpd-ea-php56___lsphp .php .php5 .phtml





AddHandler application/octet-stream .step .dwg .wmf .package





AddHandler application/vnd.android.package-archive .apk .package





</IfModule>